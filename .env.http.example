# ── Required ─────────────────────────────────────────────────────────────────

# 32-byte AES-256 key for encrypting stored AnyList passwords (hex, 64 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# KEEP THIS SAFE — losing it means stored credentials cannot be decrypted.
SERVER_SECRET_KEY=replace_with_64_char_hex_string

# Secret used to sign Express session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_random_string

# ── Optional ─────────────────────────────────────────────────────────────────

# The public HTTPS URL served by Cloudflare Tunnel.
# If not set, the server derives it from the incoming request's Host header —
# which works correctly behind Cloudflare Tunnel without any configuration.
# Set this explicitly if you need a stable value in logs or for debugging.
# BASE_URL=https://anylist.yourdomain.com

# Port the HTTP server listens on (default: 3000)
# PORT=3000

# Path to the allowed emails whitelist inside the container (default: /config/allowed-emails.txt)
# Set automatically by docker-compose.yml — only override if not using Docker Compose.
# ALLOWED_EMAILS_FILE=/config/allowed-emails.txt

# Google OAuth — leave blank to disable Google Sign-In
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BASE_URL}/auth/google/callback  (not needed for Sign In With Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# How long to keep AnyList WebSocket connections open after last use (default: 30 min)
# ANYLIST_SESSION_IDLE_MINUTES=30

# Cloudflare Tunnel token (for the cloudflared sidecar in docker-compose.yml)
# CLOUDFLARE_TUNNEL_TOKEN=
