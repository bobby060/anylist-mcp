# ============================================================================
# AnyList MCP Server - Environment Configuration
# ============================================================================
# 
# This file contains all environment variables used by the AnyList MCP server.
# Copy this file to .env and fill in your actual values.
# 
# SECURITY NOTE: Never commit your .env file to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED: AnyList Authentication
# ----------------------------------------------------------------------------
# These credentials are required for the AnyList MCP server to function.
# You can obtain these from your AnyList account settings.

ANYLIST_EMAIL="your_anylist_email@example.com"        # Required: Your AnyList account email address
ANYLIST_PASSWORD="your_anylist_password"              # Required: Your AnyList account password

# ----------------------------------------------------------------------------
# OPTIONAL: AnyList Configuration
# ----------------------------------------------------------------------------
# These settings allow you to customize the AnyList connection behavior.

ANYLIST_CREDENTIALS_FILE="~/.anylist_credentials"     # Optional: Path to credentials file (default: ~/.anylist_credentials)
ANYLIST_API_BASE_URL="https://api.anylist.com"        # Optional: Custom API base URL (use default unless specified)
ANYLIST_TIMEOUT="30000"                               # Optional: Request timeout in milliseconds (default: 30000)
ANYLIST_RETRY_ATTEMPTS="3"                            # Optional: Number of retry attempts on failure (default: 3, max: 10)
ANYLIST_RETRY_DELAY="1000"                            # Optional: Delay between retries in milliseconds

# Debug and Logging Configuration
NODE_ENV="development"                               # Environment: development, production, test
DEBUG_MODE="true"                                   # Enable debug mode (true/false)
LOG_LEVEL="info"                                    # Log level: error, warn, info, http, verbose, debug
LOG_DIRECTORY="./logs"                              # Directory for log files
ENABLE_CONSOLE_LOGGING="true"                       # Enable console logging (true/false)
ENABLE_FILE_LOGGING="true"                          # Enable file logging (true/false)
ENABLE_LOG_ROTATION="true"                          # Enable log rotation (true/false)
LOG_MAX_SIZE="20m"                                  # Maximum log file size
LOG_MAX_FILES="14d"                                 # Maximum number of log files to keep
LOG_DATE_PATTERN="YYYY-MM-DD"                       # Date pattern for log rotation
ENABLE_TIMESTAMP="true"                             # Enable timestamps in logs (true/false)
ENABLE_LOG_COLORS="true"                            # Enable colors in console logs (true/false)
ENABLE_PERFORMANCE_LOGGING="true"                   # Enable performance logging (true/false)
ENABLE_AUDIT_LOGGING="true"                         # Enable audit logging (true/false)

# Debug Configuration
DEBUG_LOG_LEVEL="debug"                             # Debug log level
DEBUG_CATEGORIES=""                                 # Debug categories (comma-separated)
DEBUG_INCLUDE_STACK_TRACE="true"                    # Include stack traces in debug logs
DEBUG_MAX_OBJECT_DEPTH="3"                         # Maximum object depth for debugging
DEBUG_MAX_ARRAY_LENGTH="10"                        # Maximum array length for debugging
DEBUG_ENABLE_FUNCTION_TRACING="true"                # Enable function call tracing
DEBUG_ENABLE_PERFORMANCE_TRACING="true"             # Enable performance tracing
DEBUG_ENABLE_MEMORY_TRACKING="true"                 # Enable memory tracking

# Error Handler Configuration
ENABLE_ERROR_METRICS="true"                         # Enable error metrics collection
MAX_RECENT_ERRORS="100"                             # Maximum number of recent errors to keep
ENABLE_ERROR_STACK_TRACE="true"                     # Enable stack traces in error logs
ENABLE_ERROR_DEBUGGING="true"                       # Enable error debugging
ENABLE_ERROR_AUDIT_LOGGING="true"                   # Enable error audit logging
ENABLE_ERROR_SECURITY_LOGGING="true"                # Enable error security logging
ENABLE_ERROR_PERFORMANCE_TRACKING="true"            # Enable error performance tracking
ENABLE_ERROR_AUTO_REPORT="true"                     # Enable automatic error reporting
ERROR_REPORT_THRESHOLD="high"                       # Error severity threshold for auto-reporting (low, medium, high, critical) (default: 1000)

# ----------------------------------------------------------------------------
# OPTIONAL: Server Configuration
# ----------------------------------------------------------------------------
# These settings control how the MCP server operates.

MCP_SERVER_PORT="3000"                                # Optional: Port for MCP server (default: 3000)
LOG_LEVEL="info"                                      # Optional: Logging level - error, warn, info, debug (default: info)
NODE_ENV="development"                                # Optional: Node.js environment - development, production, test (default: development)

# ----------------------------------------------------------------------------
# OPTIONAL: Task Master AI Integration
# ----------------------------------------------------------------------------
# These API keys enable Task Master AI features. At least one is required for AI features.

ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Recommended: Claude models - Format: sk-ant-api03-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # Recommended: Research features - Format: pplx-...
OPENAI_API_KEY="your_openai_api_key_here"             # Optional: OpenAI/OpenRouter models - Format: sk-proj-...
GOOGLE_API_KEY="your_google_api_key_here"             # Optional: Google Gemini models
MISTRAL_API_KEY="your_mistral_key_here"               # Optional: Mistral AI models
XAI_API_KEY="YOUR_XAI_KEY_HERE"                       # Optional: xAI AI models
AZURE_OPENAI_API_KEY="your_azure_key_here"            # Optional: Azure OpenAI models (requires endpoint config)
OLLAMA_API_KEY="your_ollama_api_key_here"             # Optional: Remote Ollama servers that require authentication
GITHUB_API_KEY="your_github_api_key_here"             # Optional: GitHub import/export features - Format: ghp_... or github_pat_...

# ----------------------------------------------------------------------------
# CONFIGURATION NOTES
# ----------------------------------------------------------------------------
# 
# 1. ANYLIST_EMAIL and ANYLIST_PASSWORD are the only truly required variables.
# 2. The server will use sensible defaults for all optional variables.
# 3. In production, consider using higher timeout values and error-only logging.
# 4. The credentials file will be created automatically with proper permissions.
# 5. Use the verify-env script to validate your configuration: npm run verify-env
# 
# For detailed setup instructions, see README.md
# For troubleshooting, run: npm run verify-env
# ============================================================================