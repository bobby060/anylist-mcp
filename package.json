{
  "name": "anylist-mcp",
  "version": "1.1.1",
  "description": "Model Context Protocol server for AnyList integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "anylist-mcp-setup": "./bin/claude-setup"
  },
  "scripts": {
    "build": "tsc",
    "build:prod": "chmod +x scripts/build.sh && ./scripts/build.sh",
    "dev": "tsx src/index.ts",
    "dev:resilient": "tsx src/index-resilient.ts",
    "start": "node dist/index.js",
    "start:resilient": "node dist/index-resilient.js",
    "start:prod": "NODE_ENV=production pm2 start ecosystem.config.js --env production",
    "start:dev": "NODE_ENV=development pm2 start ecosystem.config.js --env development",
    "stop": "pm2 stop anylist-mcp-server",
    "restart": "pm2 restart anylist-mcp-server",
    "reload": "pm2 reload anylist-mcp-server",
    "status": "pm2 status anylist-mcp-server",
    "logs": "pm2 logs anylist-mcp-server",
    "monit": "pm2 monit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:resilience": "vitest run tests/resilience.test.ts",
    "test:prod": "NODE_ENV=production npm run test",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "verify-env": "tsx scripts/verify-env.ts",
    "deploy": "chmod +x scripts/deploy.sh && sudo ./scripts/deploy.sh",
    "health-check": "curl -f http://localhost:3000/health || exit 1",
    "security-scan": "npm audit --audit-level=moderate",
    "chaos-test": "tsx scripts/chaos-test.ts",
    "stress-test": "tsx scripts/stress-test.ts",
    "clean": "rm -rf dist logs build-report.json deployment-report.json verification-report-*.json *.tar.gz",
    "prestart": "npm run verify-env",
    "prebuild": "npm run clean && npm run lint && npm run type-check",
    "postbuild": "npm run test",
    "prestart:prod": "npm run build:prod",
    "claude-setup": "node scripts/setup-claude-desktop.js setup",
    "claude-setup:prod": "node scripts/setup-claude-desktop.js setup --production",
    "claude-remove": "node scripts/setup-claude-desktop.js remove",
    "claude-status": "node scripts/setup-claude-desktop.js status",
    "claude-help": "node scripts/setup-claude-desktop.js help",
    "mcp:install": "./install-mcp.sh",
    "mcp:validate": "node validate-config.js",
    "mcp:test": "node test-mcp-integration.js",
    "mcp:setup": "npm run build && npm run mcp:validate"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "anylist",
    "grocery",
    "recipes",
    "meal-planning",
    "ai-assistant"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@types/node-cache": "^4.1.3",
    "anylist": "github:asachs01/anylist-js",
    "commander": "^11.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "debug": "^4.3.4",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fastmcp": "^3.8.2",
    "helmet": "^7.1.0",
    "node-cache": "^5.1.2",
    "pm2": "^5.3.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
